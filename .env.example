# ╔══════════════════════════════════════════════════════════════════╗
# ║  VARIABLES DE ENTORNO — Edunexus ULS                            ║
# ║  Copia estas variables en Netlify → Site settings → Env vars    ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Base de datos Turso (producción) ─────────────────────────────────────────
# Obtén estas en https://turso.tech → tu base → Connect → libSQL
ASTRO_DB_REMOTE_URL=libsql://edunexus-geovani.aws-us-east-2.turso.io
ASTRO_DB_APP_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...

# ── IA — OpenRouter (recomendado) ────────────────────────────────────────────
# API Key en https://openrouter.ai/keys
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
# Modelos disponibles (elige uno):
#   meta-llama/llama-3.3-70b-instruct:free  ← recomendado (gratis)
#   google/gemini-2.0-flash-exp:free        ← alternativa gratis
#   openai/gpt-4o-mini                      ← costo mínimo
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Alternativas de IA (si no usas OpenRouter) ───────────────────────────────
# GROQ_API_KEY=gsk_...          # https://console.groq.com/keys
# GOOGLE_GEMINI_API_KEY=AIza... # https://aistudio.google.com/apikey
# OPENAI_API_KEY=sk-...

# ── Administrador inicial (para seed) ────────────────────────────────────────
ADMIN_EMAIL=admin@uls.edu
ADMIN_PASSWORD=AdminULS2026!

